# ====================================================
# DragonEye-Auditor: OpenEnv Configuration Template
# ====================================================

# --- Core Application Settings ---
# 'development' = Archit's local laptop / debugging mode
# 'production'  = OpenEnv Automated Judge Evaluation
ENV_MODE=development

# The port FastAPI binds to (OpenEnv requires 8000)
PORT=8000

# ====================================================
# AGENT CONFIGURATION (The "Student" Model)
# ====================================================

# --- Local Testing (Archit's RTX 4080 via Ollama) ---
AGENT_URL=http://localhost:11434/api/generate
AGENT_MODEL=sarvam:2b

# --- Production / Judge Injection ---
# (Judges: Uncomment and replace these with your evaluation endpoints)
# AGENT_URL=https://api.groq.com/openai/v1/chat/completions
# AGENT_MODEL=llama3-8b-8192
# API_KEY=your_eval_api_key_here

# ====================================================
# HARDWARE OPTIMIZATION
# ====================================================
# Prevents Ollama from unloading the model during fast step() loops
OLLAMA_MAX_LOADED_MODELS=2